{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "paths": {
      "@camilooscargbaptista/nexus-types": ["../types/src"],
      "@camilooscargbaptista/nexus-events": ["../events/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/__tests__/**"],
  "references": [
    { "path": "../types" },
    { "path": "../events" }
  ]
}
